# Backend Django database configuration
# Default values use SQLite.

DJANGO_SECRET_KEY=django-insecure-change-this-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1 localhost

# Use SQLite by default:
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=db.sqlite3

# For PostgreSQL, change to:
# DJANGO_DB_ENGINE=django.db.backends.postgresql
# DJANGO_DB_NAME=me_conceito_api
# DJANGO_DB_USER=me_conceito_user
# DJANGO_DB_PASSWORD=supersecret
# DJANGO_DB_HOST=localhost
# DJANGO_DB_PORT=5432
